# ── Engine host port ──────────────────────────────────────────────────────────
ENGINE_PORT=9001

# ── Backend MySQL credentials (engine reads from this at startup) ──────────────
# MYSQL_HOST must match the backend's MySQL container name so Docker can resolve it
MYSQL_HOST=restaurant_project-mysql
MYSQL_PORT=3306
MYSQL_ROOT=root
MYSQL_ROOT_PASSWORD=your_backend_root_password
MYSQL_DATABASE=your_backend_database_name